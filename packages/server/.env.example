PORT=3000
DB_PATH=./data/app.db
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin@123456
DEFAULT_ADMIN_REAL_NAME=系统管理员
JWT_ACCESS_SECRET=smartstock-access-secret
JWT_REFRESH_SECRET=smartstock-refresh-secret
JWT_ACCESS_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
# AI Agent 服务配置 (付费功能，联系作者获取)
# AI_API_KEY 为连接 AI Agent 服务的密钥，购买后由作者提供
AI_API_KEY=
# AI Agent 服务地址，购买后由作者提供
AI_PROMPT_SERVICE_URL=

# AI 大模型配置 (用户自行申请)
AI_PROVIDER=qwen
AI_MODEL_API_KEY=
AI_MODEL_NAME=qwen-plus
AI_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_INDUSTRY=tea
PROMPT_REQUEST_SIGNATURE_SECRET=
